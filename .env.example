# ─────────────────────────────────────────────
#  Soymicads — Variables de entorno
#  Copiá este archivo como .env.local y completá los valores.
#  NUNCA subas .env.local a Git.
# ─────────────────────────────────────────────

# Mercado Pago
# Obtenés el Access Token en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# URL pública de tu sitio (sin barra al final)
# En desarrollo: http://localhost:3000
# En producción: https://www.moodbudita.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe (para pagos en EUR — activar en el futuro)
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
